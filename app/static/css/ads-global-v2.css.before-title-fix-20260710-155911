/* =========================================================
   ADS ERP GLOBAL DESIGN SYSTEM V2
   Product-aligned with capability dashboard
   Authoritative visual override layer
========================================================= */

:root {
    --ads-v2-bg: #080b12;
    --ads-v2-bg-soft: #0b1019;

    --ads-v2-surface: #0f1724;
    --ads-v2-surface-2: #111b2a;
    --ads-v2-surface-3: #162235;
    --ads-v2-surface-hover: #18263a;

    --ads-v2-border:
        rgba(89, 119, 168, 0.18);

    --ads-v2-border-strong:
        rgba(59, 130, 246, 0.32);

    --ads-v2-text: #f4f7fb;
    --ads-v2-text-soft: #d7deea;
    --ads-v2-muted: #8f9bb3;

    --ads-v2-primary: #2563eb;
    --ads-v2-primary-soft: #3b82f6;
    --ads-v2-primary-bright: #60a5fa;
    --ads-v2-primary-deep: #1d4ed8;

    --ads-v2-success: #22c55e;
    --ads-v2-warning: #f59e0b;
    --ads-v2-danger: #ef4444;

    --ads-v2-radius-sm: 9px;
    --ads-v2-radius-md: 13px;
    --ads-v2-radius-lg: 18px;

    --ads-v2-shadow:
        0 16px 38px rgba(0, 0, 0, 0.22);
}

/* =========================================================
   1. GLOBAL CANVAS
========================================================= */

html,
body {
    background:
        #080b12 !important;
}

body {
    color:
        var(--ads-v2-text) !important;
}

.wrapper {
    background:
        #080b12 !important;
}

.content-wrapper {
    background:
        radial-gradient(
            circle at 8% 0%,
            rgba(37, 99, 235, 0.08),
            transparent 28%
        ),
        linear-gradient(
            145deg,
            #080b12 0%,
            #0b1019 52%,
            #090d15 100%
        ) !important;

    color:
        var(--ads-v2-text) !important;
}

.content-wrapper > .content {
    padding-top:
        18px !important;

    padding-bottom:
        24px !important;
}

.content-wrapper .container-fluid {
    padding-left:
        20px !important;

    padding-right:
        20px !important;
}

/* =========================================================
   2. NAVBAR
========================================================= */

html body .main-header,
html body nav.main-header,
html body .navbar.main-header,
html body .main-header.navbar-white,
html body .main-header.navbar-light {
    min-height:
        58px !important;

    background:
        linear-gradient(
            180deg,
            rgba(15, 23, 36, 0.98),
            rgba(8, 12, 20, 0.98)
        ) !important;

    border-bottom:
        1px solid var(--ads-v2-border) !important;

    box-shadow:
        0 12px 30px rgba(0, 0, 0, 0.24) !important;
}

html body .main-header .nav-link {
    color:
        var(--ads-v2-text-soft) !important;

    transition:
        color .2s ease,
        background .2s ease,
        border-color .2s ease !important;
}

html body .main-header .nav-link:hover {
    color:
        #ffffff !important;
}

html body .main-header
[data-widget="pushmenu"] {
    width:
        38px !important;

    height:
        38px !important;

    display:
        inline-flex !important;

    align-items:
        center !important;

    justify-content:
        center !important;

    margin-top:
        2px !important;

    color:
        var(--ads-v2-primary-bright) !important;

    background:
        rgba(37, 99, 235, 0.10) !important;

    border:
        1px solid rgba(59, 130, 246, 0.24) !important;

    border-radius:
        10px !important;
}

html body .main-header
[data-widget="pushmenu"]:hover {
    color:
        #ffffff !important;

    background:
        var(--ads-v2-primary) !important;

    border-color:
        var(--ads-v2-primary) !important;
}

html body .main-header .text-primary {
    color:
        #dce7f7 !important;
}

html body .main-header .badge-success {
    color:
        #ffffff !important;

    background:
        linear-gradient(
            135deg,
            var(--ads-v2-primary),
            var(--ads-v2-primary-deep)
        ) !important;

    border:
        1px solid rgba(96, 165, 250, 0.22) !important;
}

/* =========================================================
   3. SIDEBAR
========================================================= */

html body .main-sidebar,
html body .main-sidebar::before {
    background:
        linear-gradient(
            180deg,
            #0d1420 0%,
            #080c13 54%,
            #070a10 100%
        ) !important;

    border-right:
        1px solid var(--ads-v2-border) !important;

    box-shadow:
        14px 0 34px rgba(0, 0, 0, 0.18) !important;
}

html body .brand-link {
    background:
        rgba(8, 12, 20, 0.72) !important;

    border-bottom:
        1px solid var(--ads-v2-border) !important;
}

html body .brand-link:hover {
    background:
        rgba(37, 99, 235, 0.055) !important;
}

html body .sidebar {
    padding-top:
        10px !important;
}

html body .nav-sidebar .nav-header {
    color:
        #65738a !important;

    font-size:
        10px !important;

    font-weight:
        850 !important;

    letter-spacing:
        0.12em !important;

    text-transform:
        uppercase !important;

    padding-top:
        18px !important;

    padding-bottom:
        8px !important;
}

html body .nav-sidebar > .nav-item {
    margin:
        2px 7px !important;
}

html body .nav-sidebar .nav-link {
    min-height:
        42px !important;

    display:
        flex !important;

    align-items:
        center !important;

    color:
        #aeb9ca !important;

    background:
        transparent !important;

    border:
        1px solid transparent !important;

    border-radius:
        10px !important;

    transition:
        color .2s ease,
        background .2s ease,
        border-color .2s ease,
        transform .2s ease !important;
}

html body .nav-sidebar .nav-link:hover {
    color:
        #ffffff !important;

    background:
        rgba(37, 99, 235, 0.09) !important;

    border-color:
        rgba(59, 130, 246, 0.16) !important;

    transform:
        translateX(2px);
}

html body .nav-sidebar .nav-link.active {
    color:
        #ffffff !important;

    background:
        linear-gradient(
            135deg,
            rgba(37, 99, 235, 0.30),
            rgba(29, 78, 216, 0.16)
        ) !important;

    border-color:
        rgba(59, 130, 246, 0.30) !important;

    box-shadow:
        0 10px 24px rgba(37, 99, 235, 0.12) !important;
}

html body .nav-sidebar .nav-icon {
    color:
        #73839b !important;

    transition:
        color .2s ease !important;
}

html body .nav-sidebar .nav-link:hover .nav-icon,
html body .nav-sidebar .nav-link.active .nav-icon {
    color:
        var(--ads-v2-primary-bright) !important;
}

html body .nav-treeview {
    padding-left:
        6px !important;
}

html body .nav-treeview > .nav-item > .nav-link {
    color:
        #8f9bb0 !important;

    background:
        rgba(255, 255, 255, 0.018) !important;
}

html body .nav-treeview > .nav-item > .nav-link:hover,
html body .nav-treeview > .nav-item > .nav-link.active {
    color:
        #ffffff !important;

    background:
        rgba(37, 99, 235, 0.085) !important;
}

/* =========================================================
   4. PAGE TYPOGRAPHY
========================================================= */

.content-header h1,
.content h1,
.content h2,
.content h3,
.content h4,
.content h5,
.content h6 {
    color:
        var(--ads-v2-text) !important;
}

.content-header h1 {
    font-weight:
        820 !important;

    letter-spacing:
        -0.025em !important;
}

.text-muted {
    color:
        var(--ads-v2-muted) !important;
}

a {
    color:
        var(--ads-v2-primary-bright);
}

a:hover {
    color:
        #93c5fd;
}

/* =========================================================
   5. CARDS
========================================================= */

.card {
    background:
        linear-gradient(
            145deg,
            rgba(15, 23, 36, 0.98),
            rgba(9, 14, 23, 0.98)
        ) !important;

    color:
        var(--ads-v2-text) !important;

    border:
        1px solid var(--ads-v2-border) !important;

    border-radius:
        var(--ads-v2-radius-lg) !important;

    box-shadow:
        var(--ads-v2-shadow) !important;

    overflow:
        hidden !important;
}

.card-header {
    background:
        rgba(255, 255, 255, 0.018) !important;

    border-bottom:
        1px solid var(--ads-v2-border) !important;
}

.card-title {
    color:
        #ffffff !important;

    font-weight:
        800 !important;
}

.card-footer {
    background:
        rgba(255, 255, 255, 0.018) !important;

    border-top:
        1px solid var(--ads-v2-border) !important;
}

.card-primary.card-outline,
.card-success.card-outline,
.card-info.card-outline,
.card-warning.card-outline,
.card-danger.card-outline,
.card-secondary.card-outline {
    border-top:
        1px solid var(--ads-v2-border-strong) !important;
}

/* =========================================================
   6. FORMS
========================================================= */

label {
    color:
        var(--ads-v2-text-soft) !important;

    font-weight:
        650 !important;
}

.form-control,
.custom-select,
select.form-control,
input.form-control,
textarea.form-control,
.input-group-text,
.select2-container--default
.select2-selection--single {
    min-height:
        42px !important;

    color:
        #ffffff !important;

    background:
        #0c1420 !important;

    border:
        1px solid var(--ads-v2-border) !important;

    border-radius:
        10px !important;

    box-shadow:
        none !important;
}

.form-control:focus,
.custom-select:focus,
select.form-control:focus,
input.form-control:focus,
textarea.form-control:focus {
    color:
        #ffffff !important;

    background:
        #101a29 !important;

    border-color:
        var(--ads-v2-primary-soft) !important;

    box-shadow:
        0 0 0 3px
        rgba(59, 130, 246, 0.13) !important;
}

.form-control::placeholder {
    color:
        #64748b !important;
}

select option {
    color:
        #ffffff !important;

    background:
        #0f1724 !important;
}

.input-group-text {
    color:
        var(--ads-v2-muted) !important;
}

/* =========================================================
   7. SELECT2
========================================================= */

.select2-container--default
.select2-selection--single {
    display:
        flex !important;

    align-items:
        center !important;
}

.select2-container--default
.select2-selection--single
.select2-selection__rendered {
    color:
        #ffffff !important;

    line-height:
        normal !important;
}

.select2-dropdown {
    color:
        var(--ads-v2-text) !important;

    background:
        var(--ads-v2-surface-2) !important;

    border:
        1px solid var(--ads-v2-border) !important;
}

.select2-container--default
.select2-results__option--highlighted[aria-selected] {
    color:
        #ffffff !important;

    background:
        var(--ads-v2-primary) !important;
}

/* =========================================================
   8. BUTTONS
========================================================= */

.btn {
    border-radius:
        9px !important;

    font-weight:
        750 !important;

    box-shadow:
        none !important;

    transition:
        transform .18s ease,
        filter .18s ease,
        background .18s ease !important;
}

.btn-primary,
.btn-success {
    color:
        #ffffff !important;

    background:
        linear-gradient(
            135deg,
            var(--ads-v2-primary),
            var(--ads-v2-primary-deep)
        ) !important;

    border-color:
        var(--ads-v2-primary) !important;

    box-shadow:
        0 8px 22px
        rgba(37, 99, 235, 0.20) !important;
}

.btn-primary:hover,
.btn-success:hover {
    transform:
        translateY(-1px);

    filter:
        brightness(1.08);
}

.btn-secondary {
    color:
        #ffffff !important;

    background:
        #182235 !important;

    border-color:
        var(--ads-v2-border-strong) !important;
}

.btn-info {
    color:
        #ffffff !important;

    background:
        #152238 !important;

    border-color:
        rgba(59, 130, 246, 0.38) !important;
}

.btn-warning {
    color:
        #ffffff !important;

    background:
        var(--ads-v2-warning) !important;

    border-color:
        var(--ads-v2-warning) !important;
}

.btn-danger {
    color:
        #ffffff !important;

    background:
        var(--ads-v2-danger) !important;

    border-color:
        var(--ads-v2-danger) !important;
}

/* =========================================================
   9. TABLES
========================================================= */

.table-responsive {
    background:
        transparent !important;

    border-radius:
        12px !important;
}

.table {
    color:
        var(--ads-v2-text-soft) !important;

    background:
        transparent !important;
}

.table thead th,
.table .thead-light th,
.table .thead-dark th {
    color:
        #91a1b9 !important;

    background:
        #0c1420 !important;

    border-top:
        0 !important;

    border-bottom:
        1px solid var(--ads-v2-border) !important;

    font-size:
        11px !important;

    font-weight:
        800 !important;

    letter-spacing:
        0.045em !important;

    text-transform:
        uppercase !important;
}

.table tbody td {
    color:
        #d8e0ec !important;

    background:
        transparent !important;

    border-top:
        1px solid rgba(255, 255, 255, 0.055) !important;

    vertical-align:
        middle !important;
}

.table-bordered,
.table-bordered th,
.table-bordered td {
    border-color:
        var(--ads-v2-border) !important;
}

.table-striped tbody tr:nth-of-type(odd) {
    background:
        rgba(255, 255, 255, 0.014) !important;
}

.table-hover tbody tr:hover {
    background:
        rgba(37, 99, 235, 0.065) !important;
}

/* =========================================================
   10. BADGES
========================================================= */

.badge {
    border-radius:
        999px !important;

    font-weight:
        800 !important;
}

.badge-primary,
.badge-info {
    color:
        #bfdbfe !important;

    background:
        rgba(37, 99, 235, 0.16) !important;
}

.badge-success {
    color:
        #86efac !important;

    background:
        rgba(34, 197, 94, 0.14) !important;
}

.badge-warning {
    color:
        #fde68a !important;

    background:
        rgba(245, 158, 11, 0.14) !important;
}

.badge-danger {
    color:
        #fca5a5 !important;

    background:
        rgba(239, 68, 68, 0.14) !important;
}

.badge-light {
    color:
        var(--ads-v2-text-soft) !important;

    background:
        #172235 !important;

    border:
        1px solid var(--ads-v2-border) !important;
}

/* =========================================================
   11. INFO BOXES
========================================================= */

.info-box {
    color:
        var(--ads-v2-text) !important;

    background:
        linear-gradient(
            145deg,
            rgba(15, 23, 36, 0.98),
            rgba(9, 14, 23, 0.98)
        ) !important;

    border:
        1px solid var(--ads-v2-border) !important;

    border-radius:
        16px !important;

    box-shadow:
        var(--ads-v2-shadow) !important;

    overflow:
        hidden !important;
}

.info-box-icon {
    color:
        #ffffff !important;

    background:
        linear-gradient(
            145deg,
            rgba(37, 99, 235, 0.34),
            rgba(29, 78, 216, 0.15)
        ) !important;

    border-right:
        1px solid rgba(59, 130, 246, 0.20) !important;
}

.info-box-text {
    color:
        var(--ads-v2-muted) !important;
}

.info-box-number {
    color:
        #ffffff !important;
}

/* =========================================================
   12. SMALL BOXES
========================================================= */

.small-box,
.small-box.bg-info,
.small-box.bg-success,
.small-box.bg-danger,
.small-box.bg-warning,
.small-box.bg-primary,
.small-box.bg-secondary {
    color:
        var(--ads-v2-text) !important;

    background:
        linear-gradient(
            145deg,
            rgba(15, 23, 36, 0.98),
            rgba(9, 14, 23, 0.98)
        ) !important;

    border:
        1px solid var(--ads-v2-border) !important;

    border-radius:
        16px !important;

    box-shadow:
        var(--ads-v2-shadow) !important;

    overflow:
        hidden !important;
}

.small-box .inner h3 {
    color:
        #ffffff !important;
}

.small-box .inner p {
    color:
        var(--ads-v2-text-soft) !important;
}

.small-box .icon {
    color:
        rgba(96, 165, 250, 0.12) !important;
}

/* =========================================================
   13. ALERTS
========================================================= */

.alert {
    color:
        var(--ads-v2-text-soft) !important;

    background:
        var(--ads-v2-surface) !important;

    border:
        1px solid var(--ads-v2-border) !important;

    border-radius:
        12px !important;
}

.alert-success {
    border-color:
        rgba(34, 197, 94, 0.28) !important;
}

.alert-warning {
    border-color:
        rgba(245, 158, 11, 0.28) !important;
}

.alert-danger {
    border-color:
        rgba(239, 68, 68, 0.28) !important;
}

.alert-info {
    border-color:
        rgba(59, 130, 246, 0.28) !important;
}

/* =========================================================
   14. MODALS + DROPDOWNS
========================================================= */

.modal-content,
.dropdown-menu {
    color:
        var(--ads-v2-text) !important;

    background:
        var(--ads-v2-surface-2) !important;

    border:
        1px solid var(--ads-v2-border) !important;

    border-radius:
        14px !important;

    box-shadow:
        var(--ads-v2-shadow) !important;
}

.modal-header,
.modal-footer {
    border-color:
        var(--ads-v2-border) !important;
}

.dropdown-item {
    color:
        var(--ads-v2-text-soft) !important;
}

.dropdown-item:hover,
.dropdown-item:focus {
    color:
        #ffffff !important;

    background:
        rgba(37, 99, 235, 0.12) !important;
}

/* =========================================================
   15. PAGINATION
========================================================= */

.page-link {
    color:
        var(--ads-v2-text-soft) !important;

    background:
        #111b2a !important;

    border-color:
        var(--ads-v2-border) !important;
}

.page-link:hover {
    color:
        #ffffff !important;

    background:
        rgba(37, 99, 235, 0.14) !important;

    border-color:
        var(--ads-v2-border-strong) !important;
}

.page-item.active .page-link {
    color:
        #ffffff !important;

    background:
        var(--ads-v2-primary) !important;

    border-color:
        var(--ads-v2-primary) !important;
}

/* =========================================================
   16. FOOTER
========================================================= */

.main-footer {
    color:
        var(--ads-v2-muted) !important;

    background:
        #080c13 !important;

    border-top:
        1px solid var(--ads-v2-border) !important;
}

/* =========================================================
   17. SCROLLBAR
========================================================= */

::-webkit-scrollbar {
    width:
        9px;

    height:
        9px;
}

::-webkit-scrollbar-track {
    background:
        #080b12;
}

::-webkit-scrollbar-thumb {
    background:
        #26364f;

    border-radius:
        999px;
}

::-webkit-scrollbar-thumb:hover {
    background:
        var(--ads-v2-primary-soft);
}

/* =========================================================
   18. RESPONSIVE
========================================================= */

@media (max-width: 991.98px) {
    html body .main-sidebar,
    html body .main-sidebar::before {
        background:
            linear-gradient(
                180deg,
                #0d1420,
                #070a10
            ) !important;
    }

    .content-wrapper > .content {
        padding-top:
            16px !important;
    }
}

@media (max-width: 767.98px) {
    .content-wrapper .container-fluid {
        padding-left:
            12px !important;

        padding-right:
            12px !important;
    }

    .card,
    .info-box,
    .small-box {
        border-radius:
            14px !important;
    }

    .table-responsive {
        border-radius:
            12px !important;
    }
}

/* =========================================================
   19. PRINT SAFETY
========================================================= */

@media print {
    body,
    .wrapper,
    .content-wrapper,
    .card,
    .table,
    .table tbody td,
    .table thead th {
        color:
            #000000 !important;

        background:
            #ffffff !important;
    }

    .main-sidebar,
    .main-header,
    .main-footer {
        display:
            none !important;
    }
}

/* =========================================================
   20. HEADER ACTION / BUTTON OVERLAY COMPATIBILITY FIX
   Prevent buttons from overlapping titles across ERP pages
========================================================= */

/* Shared card headers must support title + actions safely */
.card-header {
    position: relative !important;
    min-height: 52px;
}

/* Clear legacy floated children */
.card-header::after,
.content-header::after {
    content: "";
    display: table;
    clear: both;
}

/* Keep card titles inside available width */
.card-header .card-title {
    max-width: calc(100% - 170px);
    margin-bottom: 0 !important;
    line-height: 1.45 !important;
}

/* Right-side action controls stay in normal visual lane */
.card-header > .float-right,
.card-header > .card-tools,
.card-header > .btn-group {
    position: relative !important;
    z-index: 2;
}

/* Prevent action buttons from escaping header boundaries */
.card-header .btn,
.content-header .btn {
    white-space: nowrap !important;
}

/* Safer spacing for floated actions */
.card-header > .float-right {
    margin-left: 12px !important;
}

/* AdminLTE card tools compatibility */
.card-header .card-tools {
    top: auto !important;
    right: auto !important;
    margin-right: 0 !important;
}

/* Flex headers used by many ERP templates */
.card-header.d-flex {
    align-items: center !important;
    gap: 12px !important;
}

.card-header.d-flex .card-title {
    flex: 1 1 auto !important;
    min-width: 0 !important;
    max-width: none !important;
}

.card-header.d-flex .btn,
.card-header.d-flex .btn-group,
.card-header.d-flex .card-tools {
    flex: 0 0 auto !important;
}

/* Small screens: actions move below title instead of overlay */
@media (max-width: 767.98px) {
    .card-header .card-title {
        max-width: 100% !important;
    }

    .card-header > .float-right {
