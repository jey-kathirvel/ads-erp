{% extends "layouts/base.html" %}

{% block content %}

<form method="post" action="/purchase/save">

<div class="card card-success">

    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-shopping-cart"></i>
            Purchase Entry
        </h3>
    </div>

    <div class="card-body">

        <!-- Header Information -->

        <div class="row">

            <div class="col-md-6 mb-3">

                <label><strong>Supplier</strong></label>

                <select class="form-control" name="supplier_id" required>

                    {% for supplier in suppliers %}
                    <option value="{{ supplier.id }}">
                        {{ supplier.supplier_name }}
                    </option>
                    {% endfor %}

                </select>

            </div>

            <div class="col-md-3 mb-3">

                <label><strong>Purchase Date</strong></label>

                <input
                    type="date"
                    class="form-control"
                    value="{{ today }}">

            </div>

            <div class="col-md-3 mb-3">

                <label><strong>Payment Mode</strong></label>

                <select
                    class="form-control"
                    name="payment_mode">

                    <option>Cash</option>
                    <option>UPI</option>
                    <option>Bank</option>
                    <option>Credit</option>

                </select>

            </div>

        </div>

        <hr>

        <!-- Purchase Items -->

        <h5>
            <i class="fas fa-box"></i>
            Purchase Items
        </h5>

        <div id="purchaseBody">

            <div class="card border item-row mb-3">

                <div class="card-body p-3">

                    <div class="form-group">

                        <label>Product</label>

                        <select
                            class="form-control product"
                            name="product_id">

                            {% for product in products %}

                            <option
                                value="{{ product.id }}"
                                data-rate="{{ product.purchase_price }}"
                                data-gst="{{ product.gst_percentage }}">

                                {{ product.product_name }}

                            </option>

                            {% endfor %}

                        </select>

                    </div>

                    <div class="row">

                        <div class="col-6">

                            <label>Qty</label>

                            <input
                                type="number"
                                class="form-control qty"
                                name="qty"
                                value="1">

                        </div>

                        <div class="col-6">

                            <label>Rate</label>

                            <input
                                type="number"
                                step="0.01"
                                class="form-control rate"
                                name="rate"
                                value="0">

                        </div>

                    </div>

                    <div class="row mt-2">

                        <div class="col-6">

                            <label>GST %</label>

                            <input
                                type="number"
                                class="form-control gst"
                                name="gst"
                                value="18">

                        </div>

                        <div class="col-6">

                            <label>Line Total</label>

                            <input
                                type="number"
                                class="form-control total"
                                name="total"
                                value="0"
                                readonly>

                        </div>

                    </div>

                    <div class="mt-3 text-right">

                        <button
                            type="button"
                            class="btn btn-danger removeRow">

                            <i class="fas fa-trash"></i>

                        </button>

                    </div>

                </div>

            </div>

        </div>

        <button
            type="button"
            id="addRow"
            class="btn btn-success">

            <i class="fas fa-plus"></i>
            Add Product

        </button>

        <hr>

        <!-- Summary -->

        <div class="row">

            <div class="col-md-4 mb-2">

                <div class="info-box">

                    <span class="info-box-icon bg-info">
                        <i class="fas fa-calculator"></i>
                    </span>

                    <div class="info-box-content">

                        <span class="info-box-text">
                            Subtotal
                        </span>

                        <span
                            class="info-box-number"
                            id="subtotal">

                            ₹0.00

                        </span>

                    </div>

                </div>

            </div>

            <div class="col-md-4 mb-2">

                <div class="info-box">

                    <span class="info-box-icon bg-warning">
                        <i class="fas fa-percent"></i>
                    </span>

                    <div class="info-box-content">

                        <span class="info-box-text">
                            GST
                        </span>

                        <span
                            class="info-box-number"
                            id="gsttotal">

                            ₹0.00

                        </span>

                    </div>

                </div>

            </div>

            <div class="col-md-4 mb-2">

                <div class="info-box">

                    <span class="info-box-icon bg-success">
                        <i class="fas fa-rupee-sign"></i>
                    </span>

                    <div class="info-box-content">

                        <span class="info-box-text">
                            Grand Total
                        </span>

                        <span
                            class="info-box-number"
                            id="grandtotal">

                            ₹0.00

                        </span>

                    </div>

                </div>

            </div>

        </div>

        <input type="hidden" name="subtotal" id="subtotal_input">
        <input type="hidden" name="discount" value="0">
        <input type="hidden" name="taxable_amount" id="taxable_input">
        <input type="hidden" name="cgst" id="cgst_input">
        <input type="hidden" name="sgst" id="sgst_input">
        <input type="hidden" name="igst" value="0">
        <input type="hidden" name="grand_total" id="grandtotal_input">
        <input type="hidden" name="remarks" value="">

        <button
            type="submit"
            class="btn btn-primary btn-block mt-3">

            <i class="fas fa-save"></i>
            Save Purchase

        </button>

    </div>

</div>

</form>

<script>

function calculate() {

    let subtotal = 0;
    let gsttotal = 0;

    document.querySelectorAll(".item-row").forEach(function(row){

        let qty =
            parseFloat(row.querySelector(".qty").value) || 0;

        let rate =
            parseFloat(row.querySelector(".rate").value) || 0;

        let gst =
            parseFloat(row.querySelector(".gst").value) || 0;

        let lineAmount = qty * rate;

        let gstAmount = lineAmount * gst / 100;

        let total = lineAmount + gstAmount;

        row.querySelector(".total").value =
            total.toFixed(2);

        subtotal += lineAmount;
        gsttotal += gstAmount;

    });

    let grandTotal = subtotal + gsttotal;

    document.getElementById("subtotal").innerHTML =
        "₹" + subtotal.toFixed(2);

    document.getElementById("gsttotal").innerHTML =
        "₹" + gsttotal.toFixed(2);

    document.getElementById("grandtotal").innerHTML =
        "₹" + grandTotal.toFixed(2);

    document.getElementById("subtotal_input").value =
        subtotal.toFixed(2);

    document.getElementById("taxable_input").value =
        subtotal.toFixed(2);

    document.getElementById("cgst_input").value =
        (gsttotal / 2).toFixed(2);

    document.getElementById("sgst_input").value =
        (gsttotal / 2).toFixed(2);

    document.getElementById("grandtotal_input").value =
        grandTotal.toFixed(2);

}

document.addEventListener("input", calculate);

calculate();

</script>

{% endblock %}