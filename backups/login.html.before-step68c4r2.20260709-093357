<!DOCTYPE html>
<html>

<head>

    <meta charset="UTF-8">

    <title>ADS ERP Login</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <style>

        body{

            margin:0;

            height:100vh;

            display:flex;

            justify-content:center;

            align-items:center;

            background:linear-gradient(135deg,#0f172a,#2563eb);

            font-family:Arial,Helvetica,sans-serif;

        }

        .login-card{

            width:420px;

            background:white;

            border-radius:20px;

            padding:40px;

            box-shadow:0 20px 60px rgba(0,0,0,.25);

        }

        .logo{

            width:80px;

            height:80px;

            border-radius:50%;

            background:#2563eb;

            color:white;

            display:flex;

            justify-content:center;

            align-items:center;

            margin:auto;

            font-size:35px;

        }

        .title{

            text-align:center;

            margin-top:20px;

            font-size:30px;

            font-weight:bold;

        }

        .subtitle{

            text-align:center;

            color:gray;

            margin-bottom:30px;

        }

        .form-control{

            height:50px;

        }

        .btn-login{

            height:50px;

            font-size:18px;

        }

    </style>


<style id="adsLoginPremium68c4">
/* =========================================================
   STEP 68C4 - PREMIUM LOGIN EXPERIENCE
   Presentation only. No authentication logic changes.
   ========================================================= */

html,
body {
    min-height: 100% !important;
}

body {
    background:
        radial-gradient(
            circle at 82% 18%,
            rgba(255, 79, 0, 0.18) 0%,
            rgba(255, 79, 0, 0.055) 20%,
            transparent 43%
        ),
        radial-gradient(
            circle at 14% 82%,
            rgba(255, 110, 20, 0.08) 0%,
            transparent 34%
        ),
        linear-gradient(
            135deg,
            #050505 0%,
            #0a0a0b 48%,
            #111113 100%
        ) !important;

    color: #f7f7f8 !important;
}

/* Broad source-aware login card targeting */
.login-box,
.login-card-body,
.card,
.card-body {
    border-color:
        rgba(255, 255, 255, 0.10) !important;
}

.login-box .card,
.login-box .login-card-body,
body > .card,
body > div > .card {
    background:
        linear-gradient(
            145deg,
            rgba(29, 29, 31, 0.98),
            rgba(15, 15, 16, 0.99)
        ) !important;

    border:
        1px solid
        rgba(255, 255, 255, 0.11) !important;

    border-radius:
        24px !important;

    box-shadow:
        0 28px 80px
        rgba(0, 0, 0, 0.48),
        0 0 0 1px
        rgba(255, 79, 0, 0.035) !important;
}

.login-card-body {
    color: #f7f7f8 !important;
}

.login-logo,
.login-logo a,
.login-box h1,
.login-box h2,
.login-box h3,
.login-box strong {
    color: #ffffff !important;
}

.login-box p,
.login-box small,
.login-box .text-muted {
    color: #9da0aa !important;
}

.login-box label,
.login-card-body label {
    color: #e8e8eb !important;
    font-weight: 700 !important;
}

.login-box .form-control,
.login-card-body .form-control,
.login-box input,
.login-card-body input {
    color: #ffffff !important;

    background:
        #101011 !important;

    border:
        1px solid
        #35353a !important;

    border-radius:
        12px !important;

    min-height:
        46px !important;

    box-shadow:
        none !important;
}

.login-box .form-control:focus,
.login-card-body .form-control:focus,
.login-box input:focus,
.login-card-body input:focus {
    border-color:
        #ff5a12 !important;

    box-shadow:
        0 0 0 3px
        rgba(255, 90, 18, 0.15) !important;
}

.login-box .input-group-text,
.login-card-body .input-group-text {
    color: #ff6a1a !important;

    background:
        #151516 !important;

    border-color:
        #35353a !important;
}

.login-box .btn-primary,
.login-card-body .btn-primary,
.login-box button[type="submit"],
.login-card-body button[type="submit"] {
    color:
        #ffffff !important;

    background:
        linear-gradient(
            135deg,
            #ff4f00 0%,
            #ff6a1a 100%
        ) !important;

    border:
        1px solid
        #ff6a1a !important;

    border-radius:
        12px !important;

    min-height:
        46px !important;

    font-weight:
        800 !important;

    box-shadow:
        0 12px 28px
        rgba(255, 79, 0, 0.24) !important;
}

.login-box .btn-primary:hover,
.login-card-body .btn-primary:hover,
.login-box button[type="submit"]:hover,
.login-card-body button[type="submit"]:hover {
    transform:
        translateY(-1px);

    filter:
        brightness(1.08);

    box-shadow:
        0 16px 34px
        rgba(255, 79, 0, 0.34) !important;
}

.login-box hr,
.login-card-body hr {
    border-color:
        rgba(255, 255, 255, 0.10) !important;
}

.login-box a,
.login-card-body a {
    color:
        #ff7a35 !important;
}

/* Convert common blue circular brand icon to orange */
.login-box .bg-primary,
.login-card-body .bg-primary,
.login-box .text-bg-primary {
    background:
        linear-gradient(
            135deg,
            #ff4f00,
            #ff7a24
        ) !important;
}

/* Checkbox visibility */
.login-box input[type="checkbox"],
.login-card-body input[type="checkbox"] {
    accent-color:
        #ff5a12 !important;

    min-height:
        auto !important;
}

@media (max-width: 576px) {
    .login-box {
        width:
            calc(100% - 28px) !important;
    }

    .login-box .card,
    .login-card-body {
        border-radius:
            18px !important;
    }
}
</style>

</head>

<body>

<div class="login-card">

    <div class="logo">

        <i class="fa fa-building"></i>

    </div>

    <div class="title">

        ADS ERP

    </div>

    <div class="subtitle">

        Enterprise Resource Planning

    </div>

    {% if request.query_params.get("logout") %}

    <div class="alert alert-success">

        <i class="fa fa-check-circle"></i>

        Logged out successfully.

    </div>

    {% endif %}

    {% if message %}

    <div class="alert alert-danger">

        {{ message }}

    </div>

    {% endif %}

    <form method="post" action="/login">

        <div class="mb-3">

            <label>Email</label>

            <input

                class="form-control"

                type="email"

                name="email"

                required>

        </div>

        <div class="mb-3">

            <label>Password</label>

            <div class="input-group">

                <input

                    id="password"

                    class="form-control"

                    type="password"

                    name="password"

                    required>

                <button

                    type="button"

                    class="btn btn-outline-secondary"

                    onclick="togglePassword()">

                    <i class="fa fa-eye"></i>

                </button>

            </div>

        </div>

        <div class="form-check mb-3">

            <input

                class="form-check-input"

                type="checkbox"

                id="remember">

            <label class="form-check-label">

                Remember Me

            </label>

        </div>

        <button

            class="btn btn-primary btn-login w-100">

            <i class="fa fa-sign-in-alt"></i>

            Login

        </button>

    </form>

    <hr>

    <div class="text-center text-muted">

        ADS ERP v1.0

        <br>

        Copyright 2026 ADS Digital Solutions

    </div>

</div>

<script>

function togglePassword(){

    var x=document.getElementById("password");

    if(x.type==="password")

        x.type="text";

    else

        x.type="password";

}

</script>

</body>

</html>