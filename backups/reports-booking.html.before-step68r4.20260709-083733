<script>
document.addEventListener(
    "DOMContentLoaded",
    function () {
        const table = document.getElementById(
            "bookingReportTable"
        );

        const csvButton = document.getElementById(
            "exportBookingCsvButton"
        );

        const printButton = document.getElementById(
            "printBookingReportButton"
        );

        function normalizeCellText(cell) {
            return cell.innerText
                .replace(/\s+/g, " ")
                .trim();
        }

        function csvEscape(value) {
            const normalized = String(
                value ?? ""
            );

            return (
                '"'
                + normalized.replace(
                    /"/g,
                    '""'
                )
                + '"'
            );
        }

        function buildReportCsv() {
            if (!table) {
                throw new Error(
                    "Booking report table not found"
                );
            }

            const lines = [];

            lines.push(
                csvEscape(
                    "Akshat Royal Stay"
                )
            );

            lines.push(
                csvEscape(
                    "Booking Report"
                )
            );

            lines.push("");

            const summaryCards =
                document.querySelectorAll(
                    ".small-box"
                );

            summaryCards.forEach(
                function (card) {
                    const valueElement =
                        card.querySelector("h3");

                    const labelElement =
                        card.querySelector("p");

                    if (
                        valueElement
                        && labelElement
                    ) {
                        lines.push(
                            [
                                csvEscape(
                                    normalizeCellText(
                                        labelElement
                                    )
                                ),
                                csvEscape(
                                    normalizeCellText(
                                        valueElement
                                    )
                                ),
                            ].join(",")
                        );
                    }
                }
            );

            lines.push("");

            const rows =
                table.querySelectorAll(
                    "tr"
                );

            rows.forEach(
                function (row) {
                    const cells =
                        row.querySelectorAll(
                            "th, td"
                        );

                    if (!cells.length) {
                        return;
                    }

                    const values = [];

                    cells.forEach(
                        function (
                            cell,
                            index
                        ) {
                            const isLastColumn =
                                index
                                === cells.length - 1;

                            const isActionsColumn =
                                isLastColumn
                                && (
                                    cell.tagName
                                    === "TH"
                                    || cell.querySelector(
                                        ".btn"
                                    )
                                );

                            if (
                                isActionsColumn
                            ) {
                                return;
                            }

                            values.push(
                                csvEscape(
                                    normalizeCellText(
                                        cell
                                    )
                                )
                            );
                        }
                    );

                    lines.push(
                        values.join(",")
                    );
                }
            );

            return lines.join("\r\n");
        }

        if (csvButton) {
            csvButton.addEventListener(
                "click",
                function () {
                    try {
                        const csv =
                            buildReportCsv();

                        const bom = "\uFEFF";

                        const blob = new Blob(
                            [
                                bom + csv
                            ],
                            {
                                type:
                                    "text/csv;charset=utf-8;"
                            }
                        );

                        const url =
                            URL.createObjectURL(
                                blob
                            );

                        const link =
                            document.createElement(
                                "a"
                            );

                        const now =
                            new Date();

                        const stamp = [
                            now.getFullYear(),
                            String(
                                now.getMonth() + 1
                            ).padStart(2, "0"),
                            String(
                                now.getDate()
                            ).padStart(2, "0"),
                        ].join("-");

                        link.href = url;

                        link.download =
                            "akshat-royal-stay-booking-report-"
                            + stamp
                            + ".csv";

                        document.body.appendChild(
                            link
                        );

                        link.click();

                        link.remove();

                        URL.revokeObjectURL(
                            url
                        );

                    } catch (error) {
                        console.error(error);

                        alert(
                            "Unable to export booking report."
                        );
                    }
                }
            );
        }

        if (printButton) {
            printButton.addEventListener(
                "click",
                function () {
                    window.print();
                }
            );
        }
    }
);
</script>


